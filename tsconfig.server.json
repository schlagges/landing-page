{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist/server",
    "resolveJsonModule": true,
    "rootDir": "server",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023"
  },
  "include": ["server/**/*.ts"]
}
